# Copy to .env in the project root and fill in. NEVER commit .env.

# Required for local runs that hit the GitHub API.
# In GitHub Actions this is provided automatically as ${{ secrets.GITHUB_TOKEN }}.
GITHUB_TOKEN=

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Run sizing
REPORTS_PER_RUN=3
DISCOVERY_BATCH_SIZE=50

# GitHub API tuning
REQUEST_TIMEOUT=30
MAX_RETRIES=5
GITHUB_API_URL=https://api.github.com
